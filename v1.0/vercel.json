{
  "name": "my-sni-relay-2026",
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "edge",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, private"
        }
      ]
    }
  ],
  "env": {
    "TARGET_DOMAIN": "@target_domain"
  }
}
